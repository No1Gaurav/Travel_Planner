# ============================================================
# IBM Watsonx.ai Credentials — copy this to .env and fill in
# ============================================================

# --- Option A: IBM Cloud SaaS (*.ml.cloud.ibm.com) ----------
# IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
# IBM_API_KEY=your_ibm_cloud_api_key_here
# IBM_PROJECT_ID=your_watsonx_project_id_here

# --- Option B: Cloud Pak for Data / on-prem / dedicated -----
#   URL looks like: https://<host>.dai.cloud.ibm.com
IBM_WATSONX_URL=https://au-syd.dai.cloud.ibm.com
IBM_API_KEY=your_cpd_api_key_here
IBM_PROJECT_ID=your_watsonx_project_id_here
IBM_CPD_USERNAME=your_cpd_login_username_here
IBM_CPD_VERSION=5.1

# ============================================================
# Flask Configuration
# ============================================================
FLASK_SECRET_KEY=your_super_secret_flask_key_here
FLASK_DEBUG=False
PORT=5000
